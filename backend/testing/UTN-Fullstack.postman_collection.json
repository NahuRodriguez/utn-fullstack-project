                {
                    "name": "Get Products with filters",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/products?page=1&limit=10&sort=price-asc&category=CATEGORY_ID&search=zapatilla",
                            "host": ["{{base_url}}"],
                            "path": ["products"],
                            "query": [
                                { "key": "page", "value": "1" },
                                { "key": "limit", "value": "10" },
                                { "key": "sort", "value": "price-asc" },
                                { "key": "category", "value": "CATEGORY_ID" },
                                { "key": "search", "value": "zapatilla" }
                            ]
                        }
                    }
                },
                {
                    "name": "Create Product (con imagen)",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                { "key": "name", "value": "Zapatilla Deportiva", "type": "text" },
                                { "key": "description", "value": "Zapatilla cómoda para correr", "type": "text" },
                                { "key": "price", "value": "25000", "type": "text" },
                                { "key": "stock", "value": "50", "type": "text" },
                                { "key": "categories[0]", "value": "CATEGORY_ID", "type": "text" },
                                { "key": "image", "value": "", "type": "file", "src": "" }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/products",
                            "host": ["{{base_url}}"],
                            "path": ["products"]
                        }
                    }
                },
                {
                    "name": "Update Product",
                    "request": {
                        "method": "PUT",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Zapatilla Deportiva Premium\",\n    \"price\": 32000,\n    \"stock\": 40\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/products/:id",
                            "host": ["{{base_url}}"],
                            "path": ["products", ":id"],
                            "variable": [
                                { "key": "id", "value": "PRODUCT_ID" }
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Product (soft)",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/products/:id",
                            "host": ["{{base_url}}"],
                            "path": ["products", ":id"],
                            "variable": [
                                { "key": "id", "value": "PRODUCT_ID" }
                            ]
                        }
                    }
                },
                {
                    "name": "Restore Product",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/products/restore/:id",
                            "host": ["{{base_url}}"],
                            "path": ["products", "restore", ":id"],
                            "variable": [
                                { "key": "id", "value": "PRODUCT_ID" }
                            ]
                        }
                    }
                }
            ]
